# Google Cloud: the project and the (public, read-only) bucket that holds the
# JSON data files, plus a service-account key with write access to that bucket.
GCP_PROJECT_ID = "your-gcp-project-id"
GCP_BUCKET_NAME = "your-gcs-bucket-name"
GOOGLE_APPLICATION_CREDENTIALS = "path/to/service-account.json"

# Google Health API OAuth is NOT set here. Put your OAuth client secret at
# secrets/client_secret_health.json; the first run opens a browser to authorize
# and writes secrets/token_health.json (reused and auto-refreshed after that).
